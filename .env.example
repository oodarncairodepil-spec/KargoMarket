# --- Database (Express API / pg) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kargomarket
# Lokal Postgres tanpa SSL:
# DATABASE_SSL=off

# --- Supabase (wajib untuk login & verifikasi JWT di API) ---
# URL project (sama seperti VITE_SUPABASE_URL di frontend).
SUPABASE_URL=https://your-project-ref.supabase.co
# Dashboard → Settings → API → service_role (rahasia, hanya server / Vercel).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- API ---
API_PORT=4000
# Origin frontend, dipisah koma (CORS + origin terpercaya untuk POST).
APP_ORIGIN=http://localhost:5173,https://cargomarket.vercel.app

# Opsional: seed vendor demo saat bootstrap penuh (bukan user — user dari Supabase Auth + user_profiles).
# RUNTIME_DB_BOOTSTRAP=true

# --- Frontend (Vite) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Produksi: /api (Vercel rewrite) atau URL API penuh.
VITE_API_BASE_URL=https://cargomarket.vercel.app/api

# --- Data pengguna ---
# Buat pengguna di Authentication → Users (Supabase), lalu satu baris per user di public.user_profiles:
#   id = UUID yang sama dengan auth.users.id, role = 'admin' | 'customer', name = '...'
# Tanpa baris user_profiles, login sukses di Auth tetapi aplikasi menolak (no_profile).
