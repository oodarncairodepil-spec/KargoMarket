DATABASE_URL=postgres://postgres:postgres@localhost:5432/kargomarket
# Lokal: set DATABASE_SSL=off jika Postgres tanpa SSL. Di Vercel + Supabase SSL otomatis aktif.
# DATABASE_SSL=off
#
# --- Vercel + Supabase (login Express) ---
# Login memakai tabel public.user_profiles (email + password_hash bcrypt) dan public.sessions.
# Setelah deploy, pilih salah satu:
# A) Set RUNTIME_DB_BOOTSTRAP=true (sekali), deploy, lalu hapus/hindari di production permanen:
#    API akan menjalankan seed: user dari SEED_*_EMAIL / SEED_*_PASSWORD di bawah.
# B) Tanpa bootstrap: buat baris manual di Supabase → Table Editor → user_profiles,
#    atau jalankan SQL INSERT (password harus hash bcrypt, sama seperti seed).
# APP_ORIGIN harus berisi origin frontend persis, contoh: https://cargomarket.vercel.app
# RUNTIME_DB_BOOTSTRAP=true
API_PORT=4000
APP_ORIGIN=http://localhost:5173,https://cargomarket.vercel.app
SEED_ADMIN_EMAIL=admin@kargomarket.test
SEED_ADMIN_PASSWORD=Admin123!
SEED_CUSTOMER_EMAIL=customer@kargomarket.test
SEED_CUSTOMER_PASSWORD=Customer123!
# Optional: UUID from auth.users to link Express profiles (Supabase Auth)
# SEED_ADMIN_AUTH_USER_ID=
# SEED_CUSTOMER_AUTH_USER_ID=
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_BASE_URL=https://your-backend-domain.com
